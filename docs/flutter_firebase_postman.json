            {
            "name": "User Login (Firebase Auth)",
            "request": {
                "method": "POST",
                "header": [
                {
                    "key": "Content-Type",
                    "value": "application/json"
                }
                ],
                "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"user@gmail.com\",\n  \"password\": \"123456\",\n  \"returnSecureToken\": true\n}"
                },
                "url": {
                "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{FIREBASE_WEB_API_KEY}}",
                "protocol": "https",
                "host": [
                    "identitytoolkit",
                    "googleapis",
                    "com"
                ],
                "path": [
                    "v1",
                    "accounts:signInWithPassword"
                ],
                "query": [
                    {
                    "key": "key",
                    "value": "{{FIREBASE_WEB_API_KEY}}"
                    }
                ]
                },
                "description": "Firebase Auth sign-in with email and password."
            },
            "response": [
                {
                "name": "Example Response",
