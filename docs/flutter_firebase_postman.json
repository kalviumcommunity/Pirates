            {
            "name": "Create Emergency Alert (Firestore)",
            "request": {
                "method": "POST",
                "header": [
                {
                    "key": "Authorization",
                    "value": "Bearer {{FIREBASE_ID_TOKEN}}"
                },
                {
                    "key": "Content-Type",
                    "value": "application/json"
                }
                ],
                "body": {
                "mode": "raw",
                "raw": "{\n  \"fields\": {\n    \"userId\": { \"stringValue\": \"user123\" },\n    \"location\": { \"stringValue\": \"17.3850,78.4867\" },\n    \"status\": { \"stringValue\": \"active\" },\n    \"createdAt\": { \"timestampValue\": \"2025-11-13T10:00:00Z\" }\n  }\n}"
                },
                "url": {
                "raw": "https://firestore.googleapis.com/v1/projects/{{FIREBASE_PROJECT_ID}}/databases/(default)/documents/alerts",
                "protocol": "https",
                "host": [
                    "firestore",
                    "googleapis",
                    "com"
                ],
                "path": [
                    "v1",
                    "projects",
                    "{{FIREBASE_PROJECT_ID}}",
                    "databases",
                    "(default)",
                    "documents",
                    "alerts"
                ]
                },
                "description": "Create a new alert document in Firestore."
            },
            "response": []
